{
  "name": "big-red-hacks-overlay",
  "version": "0.1.0",
  "description": "Transparent Electron overlay skeleton for Big Red Hacks.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "rebuild:native": "npm rebuild better-sqlite3 --runtime=electron --target=37.2.0 --dist-url=https://electronjs.org/headers --build-from-source",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js",
    "test": "node --experimental-strip-types --test --test-isolation=none"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "electron": "^37.2.0",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "openai": "^6.34.0",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  }
}
