{
  "name": "sideklick",
  "private": true,
  "version": "0.1.10",
  "productName": "SideKlick",
  "packageManager": "pnpm@10.0.0",
  "description": "AI study sidekick desktop app for class sessions, context-aware help, and quiz generation.",
  "author": {
    "name": "Nirvaan Kohli",
    "email": "nirvaankohli@users.noreply.github.com"
  },
  "main": "apps/desktop/src/main.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "electron .",
    "dev": "pnpm run desktop:dev",
    "env:split": "node scripts/split-env.mjs",
    "dev:desktop:local-backend": "node scripts/dev-desktop-local-backend.mjs",
    "desktop:start": "electron .",
    "desktop:dev": "pnpm --filter @sideklick/desktop dev",
    "desktop:dev:rebuild": "pnpm run rebuild:native:electron && pnpm run desktop:dev",
    "backend:start": "pnpm run rebuild:native:node && node --import tsx --eval \"import('./apps/backend/src/server.ts').then((mod) => { const api = mod.startServer ? mod : mod.default; return api.startServer(); })\"",
    "backend:dev": "pnpm run rebuild:native:node && pnpm --filter @sideklick/backend dev",
    "extension:dev": "pnpm --filter @sideklick/extension dev",
    "extension:build": "pnpm --filter @sideklick/extension build",
    "kill:sideklick": "node scripts/device-specific/kill-sideklick-processes.js",
    "reset:first-launch": "node scripts/reset-first-launch.js",
    "reset:first-launch:full": "node scripts/reset-first-launch.js --full",
    "rebuild:native": "pnpm install --force",
    "rebuild:native:node": "node scripts/rebuild-native.mjs node",
    "rebuild:native:electron": "node scripts/rebuild-native.mjs electron",
    "desktop:build": "node scripts/build-desktop.mjs",
    "desktop:pack": "pnpm run rebuild:native:electron && pnpm run desktop:build && pnpm exec electron-builder --dir",
    "desktop:dist": "pnpm run rebuild:native:electron && pnpm run desktop:build && pnpm exec electron-builder -mwl --publish always",
    "desktop:dist:mac": "pnpm run rebuild:native:electron && pnpm run desktop:build && pnpm exec electron-builder --mac --publish always",
    "desktop:dist:win": "pnpm run rebuild:native:electron && pnpm run desktop:build && pnpm exec electron-builder --win --publish always",
    "desktop:dist:linux": "pnpm run rebuild:native:electron && pnpm run desktop:build && pnpm exec electron-builder --linux --publish always",
    "check": "node --check apps/desktop/src/main.js && node --check apps/desktop/src/preload.js && node --check apps/desktop/src/renderer.js && node --check apps/desktop/src/home.js",
    "test": "node scripts/run-tests.js",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.10",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "build": {
    "appId": "com.sideklick.desktop",
    "publish": [
      {
        "provider": "github",
        "owner": "nirvaankohli",
        "repo": "sideklick"
      }
    ],
    "productName": "SideKlick",
    "icon": "apps/desktop/assets/images/logo/app-icon-1024.png",
    "directories": {
      "output": "release-builds"
    },
    "files": [
      "dist/desktop/**",
      "dist/assets/**",
      "dist/native-host/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/desktop/main.cjs"
    },
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "mac": {
      "icon": "apps/desktop/assets/images/logo/app-icon-1024.png",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "dmg": {
      "title": "Install SideKlick",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "apps/desktop/assets/images/logo/app-icon-1024.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "apps/desktop/assets/images/logo/app-icon-1024.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "@langfuse/openai": "^5.3.0",
    "electron-updater": "^6.1.8",
    "@langfuse/otel": "^5.3.0",
    "@langfuse/tracing": "^5.3.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "protobufjs"
    ]
  }
}
