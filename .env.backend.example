# Backend server secrets and runtime config
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini
OPENAI_CRAM_MODEL=gpt-5.4-mini
OPENAI_ASSESSMENT_MODEL=gpt-5.4-mini
OPENAI_UPLOAD_VISION_MODEL=gpt-4.1-mini
DISABLE_OPENAI_CRAM=false
DISABLE_OPENAI_ASSESSMENT_PROFILE=false
DISABLE_OPENAI_FILE_VISION=false

BACKEND_JWT_SECRET=replace_with_a_long_random_secret
BACKEND_RATE_LIMIT_WINDOW_MS=60000
BACKEND_RATE_LIMIT_MAX_REQUESTS=120
BACKEND_AUTH_RATE_LIMIT_WINDOW_MS=60000
BACKEND_AUTH_RATE_LIMIT_MAX_REQUESTS=20
BACKEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://sideklick.app,https://www.sideklick.app
SIDEKLICK_PUBLIC_URL=http://localhost:5173
SIDEKLICK_ADMIN_SECRET=replace_with_admin_grant_secret

# Billing / Stripe Checkout
BILLING_MOCK_MODE=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BILLING_PORTAL_CONFIGURATION=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_YEARLY=
STRIPE_PRICE_MAX_MONTHLY=
STRIPE_PRICE_MAX_YEARLY=
STRIPE_PRICE_CREDITS_50=
STRIPE_PRICE_FINALS_PACK=
STRIPE_PRICE_FOUNDING_BETA_MAX_LIFETIME=

# Optional Postgres
DATABASE_URL=
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=true
POSTGRES_CA_CERT_PATH=
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_CONNECT_TIMEOUT_MS=10000

# Optional TLS for backend server
BACKEND_TLS_KEY_PATH=
BACKEND_TLS_CERT_PATH=

# Optional Langfuse backend telemetry
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
LANGFUSE_TRACING_ENVIRONMENT=development
LANGFUSE_RELEASE=
