# Core OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ASSESSMENT_MODEL=gpt-4.1-mini
OPENAI_CRAM_MODEL=gpt-4.1-mini
OPENAI_UPLOAD_VISION_MODEL=gpt-4.1-mini

# Feature flags
DISABLE_OPENAI_ASSESSMENT_PROFILE=false
DISABLE_OPENAI_CRAM=false
DISABLE_OPENAI_FILE_VISION=false

# Backend auth and limits
BACKEND_JWT_SECRET=replace_with_a_long_random_secret
BACKEND_RATE_LIMIT_WINDOW_MS=60000
BACKEND_RATE_LIMIT_MAX_REQUESTS=120
BACKEND_AUTH_RATE_LIMIT_WINDOW_MS=60000
BACKEND_AUTH_RATE_LIMIT_MAX_REQUESTS=10
BACKEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://sideklick.app,https://www.sideklick.app,https://sideklick.nirvaankohli.com
SIDEKLICK_PUBLIC_URL=http://localhost:5173
SIDEKLICK_ADMIN_SECRET=replace_with_admin_grant_secret
SIDEKLICK_ANDREAS_ENDPOINT_SECRET=replace_with_personal_analytics_secret
SIDEKLICK_WEB_VISIT_WEBHOOK_URL=
SIDEKLICK_WEB_VISIT_NOTIFY_SOURCES=instagram
SIDEKLICK_WEB_ANALYTICS_SALT=replace_with_random_analytics_salt

# Billing / Stripe Checkout
BILLING_MOCK_MODE=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BILLING_PORTAL_CONFIGURATION=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_YEARLY=
STRIPE_PRICE_MAX_MONTHLY=
STRIPE_PRICE_MAX_YEARLY=
STRIPE_PRICE_CREDITS_50=
STRIPE_PRICE_FINALS_PACK=
STRIPE_PRICE_FOUNDING_BETA_MAX_LIFETIME=

# Backend TLS (optional)
BACKEND_TLS_KEY_PATH=
BACKEND_TLS_CERT_PATH=

# Managed backend mode (optional)
VITE_MANAGED_BACKEND_URL=https://api.sideklick.app
MANAGED_BACKEND_URL=
MANAGED_BACKEND_JWT=
MANAGED_BACKEND_ALLOW_HTTP=false
MANAGED_BACKEND_ALLOW_SELF_SIGNED=false
LOCAL_API_BASE_URL=http://127.0.0.1:3001

# Bridge auth
SIDECLICK_BRIDGE_SECRET=
BRIDGE_AUTH_SECRET=

# Postgres (optional; if DATABASE_URL is unset local sqlite path is used by app code)
DATABASE_URL=
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=true
POSTGRES_CA_CERT_PATH=
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_CONNECT_TIMEOUT_MS=10000

# Langfuse (optional tracing)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
LANGFUSE_TRACING_ENVIRONMENT=development
LANGFUSE_RELEASE=
