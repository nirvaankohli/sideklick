{
  "manifest_version": 3,
  "name": "SideKlick Local Sender",
  "version": "0.1.0",
  "description": "Sends SideKlick context-menu requests to the local Electron overlay.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:4353/*",
    "http://127.0.0.1:4353/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open SideKlick",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
