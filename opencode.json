{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-6",
  "default_agent": "general",
  "shell": "/bin/zsh",
  "logLevel": "INFO",
  "share": "disabled",
  "autoupdate": "notify",
  "snapshot": true,
  "skills": {
    "paths": [".opencode/skills"]
  },
  "agent": {
    "general": {
      "description": "General purpose agent for software development tasks"
    }
  },
  "permission": {
    "edit": "deny",
    "bash": {
      "git *": "allow",
      "npm *": "allow",
      "pnpm *": "allow",
      "*": "ask"
    }
  },
  "formatter": false,
  "lsp": false
}